SECRET_KEY=django-secret-key-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DB_NAME=vision_db
DB_USER=vision_user
DB_PASSWORD=vision_password
DB_HOST=postgres
DB_PORT=5432
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
MEDIA_ROOT=/app/media
MODELS_PATH=/app/models

# Demo superuser auto-created by `seed_demo` management command
DEMO_USER=admin
DEMO_PASSWORD=admin12345
DEMO_EMAIL=admin@example.com

# Ajuste de detección / NMS (opcional). Tras cambiar: reiniciar el backend y
# los celery_worker, y reprocesar el vuelo para recalcular las detecciones.
# IoU del NMS interno de YOLO. Más bajo = quita más boxes duplicados (0.3–0.6).
YOLO_IOU_INFERENCIA=0.5
# IoU del NMS entre tiles vecinos (TIFF troceado).
YOLO_IOU_TILES=0.45
# IoS: suprime boxes anidados (uno dentro de otro) que el IoU no elimina.
# 0 desactiva; más bajo = más agresivo (0.5–0.7).
YOLO_IOS_DEDUP=0.6
# Test-Time Augmentation: sube recall, ~2-3x más lento.
YOLO_TTA=False
YOLO_AGNOSTIC_NMS=False

# Límites de conversión GeoTIFF → tiles (opcional, para proteger el servidor)
TIFF_MAX_SIZE_MB=500
TIFF_MAX_TILE_SIZE=2048
CONVERSION_TEMP_DIR=/app/media/temp_conversion
