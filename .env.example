# ==========================================================================
# Root .env.example — used by docker-compose.yml
# Copy to .env and adjust values as needed.
# ==========================================================================

# PostgreSQL
POSTGRES_DB=vision_db
POSTGRES_USER=vision_user
POSTGRES_PASSWORD=vision_password

# Exposed host ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
